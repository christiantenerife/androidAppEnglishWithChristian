<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.englishwithchristian">
    <!-- Internet permission for WebView -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EnglishWithChristian"
        tools:targetApi="31">

        <!-- Auth: pantalla de inicio -->
        <activity
            android:name=".AuthActivity"
            android:exported="true"
            android:theme="@style/Theme.EnglishWithChristian">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:label="@string/title_activity_web_view"
            android:theme="@style/Theme.EnglishWithChristian" />

        <activity
            android:name=".GrammarActivity"
            android:exported="false"
            android:label="@string/title_activity_grammar"
            android:theme="@style/Theme.EnglishWithChristian"
            android:launchMode="singleTop"/>

        <activity
            android:name=".VocabularyActivity"
            android:exported="false"
            android:label="@string/title_activity_vocabulary"
            android:theme="@style/Theme.EnglishWithChristian" />

        <activity
            android:name=".ExamsActivity"
            android:exported="false"
            android:label="@string/title_activity_exams"
            android:theme="@style/Theme.EnglishWithChristian" />

        <!-- Main: solo accesible tras login -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.EnglishWithChristian" />

    </application>

</manifest>