<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:text="English with Christian"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:text="Practise Grammar, Vocabulary and Exams at B2 level."
            android:textSize="16sp"
            android:textColor="@color/colorTextPrimary"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Category Buttons Container -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <!-- Grammar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrammar"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Grammar"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconTint="@color/colorPrimary"
                app:iconPadding="12dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="2dp"/>

            <!-- Vocabulary -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVocabulary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Vocabulary"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                app:icon="@android:drawable/ic_menu_sort_alphabetically"
                app:iconTint="@color/colorPrimary"
                app:iconPadding="12dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="2dp"/>

            <!-- Exams -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExams"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Exams"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                app:icon="@android:drawable/ic_menu_view"
                app:iconTint="@color/colorPrimary"
                app:iconPadding="12dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="2dp"/>

        </LinearLayout>

        <!-- Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Close"
            android:textAllCaps="false"
            android:textColor="@android:color/holo_red_dark"/>

    </LinearLayout>
</ScrollView>